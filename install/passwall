#!/bin/sh
IPK_URL="https://raw.githubusercontent.com/tryoo127/Aw-Packages/main/system/luci-app-passwall.ipk"
IPK_FILE="/tmp/luci-app-passwall.ipk"

echo "======================================"
echo "   INSTALL PASSWALL QWRT AW1000"
echo "======================================"
echo

fail() {
    echo "ERROR: $1"
    exit 1
}

echo "[1/8] Stop & disable services..."
/etc/init.d/passwall stop 2>/dev/null
/etc/init.d/xray stop 2>/dev/null
/etc/init.d/passwall disable 2>/dev/null
/etc/init.d/xray disable 2>/dev/null

echo
echo "[2/8] Remove old packages..."
opkg remove luci-app-passwall luci-i18n-passwall-zh-cn luci-i18n-passwall-en xray-core 2>/dev/null

echo
echo "[3/8] Clean leftover files..."
rm -rf /etc/config/passwall
rm -rf /etc/passwall
rm -rf /usr/share/passwall
rm -rf /var/etc/passwall

echo
echo "[4/8] Update package list..."
opkg update || fail "opkg update failed"

echo
echo "[5/8] Download Passwall..."
rm -f "$IPK_FILE"
wget -O "$IPK_FILE" "$IPK_URL" || fail "Download failed"

echo
echo "[6/8] Install Passwall GUI..."
opkg install "$IPK_FILE" || fail "Install GUI failed"

echo
echo "[7/8] Install Xray core..."
opkg install xray-core || fail "Install xray failed"

echo
echo "[8/8] Restart LuCI..."
/etc/init.d/uhttpd restart 2>/dev/null

rm -f "$IPK_FILE"

opkg list-installed | grep -E 'passwall|xray' || echo "Not detected"

echo
echo "Log in QWRT WebUI:"
echo "Go to -> Services -> Passwall"
sleep 2
echo
echo "Done."